{
  "name": "cp5-demo-api",
  "version": "1.0.0",
  "description": "API simples para demonstração de CI/CD no Azure DevOps (CP5)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest --ci --coverage --forceExit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": ["/node_modules/"],
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
